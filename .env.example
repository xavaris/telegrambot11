TELEGRAM_TOKEN=123456:ABCDEF
CHANNEL_ID=@twoj_kanal

SCAN_INTERVAL_MINUTES=15
STARTUP_SCAN=true

DATABASE_PATH=/app/data/offers.db
LOG_LEVEL=INFO

HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
MAX_OFFERS_PER_SOURCE=15
REQUEST_DELAY_MS=900

ONLY_MODELS=
EXCLUDED_KEYWORDS=icloud,blokada,na części,na czesci,uszkodzony,uszkodzona,do naprawy
PREFERRED_LOCATIONS=Warszawa,Kraków,Wrocław,Poznań,Gdańsk
PREFERRED_REGIONS=
MIN_DEAL_SCORE=0.00
MIN_PRICE=350
MAX_PRICE=10000
MAX_PRICE_BY_MODEL_JSON={"iphone 11":1800,"iphone 12":2400,"iphone 13":3200,"iphone 14":4200,"iphone 15":5600,"iphone 16":8000}

ENABLE_VINTED=true
ENABLE_OLX=true
ENABLE_ALLEGRO_LOKALNIE=true

VINTED_SEARCH_URL=https://www.vinted.pl/catalog?search_text=iphone&order=newest_first&page=1
OLX_SEARCH_URL=https://www.olx.pl/oferty/q-iphone/?search%5Border%5D=created_at%3Adesc
ALLEGRO_LOKALNIE_SEARCH_URL=https://allegrolokalnie.pl/oferty/q/iphone?sort=startingTime-desc

ENABLE_TRANSLATION=true
TRANSLATE_TO_LANGUAGE=pl

ENABLE_MARKET_BASELINE_REFRESH=true
BASELINE_REFRESH_INTERVAL_HOURS=24
BASELINE_MAX_OFFERS_PER_QUERY=45
BASELINE_MIN_SAMPLES_FOR_STORAGE=5
BASELINE_MIN_SAMPLES_FOR_MODEL=8

FILTER_STRICT_MODE=true
STRICT_REQUIRE_IPHONE_IN_TITLE=true
